# Sanity Studio Configuration (Obtain from https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-13
# Sanity Read Token (Viewer role token, needed for previewing drafts during ISR/Static builds)
SANITY_API_READ_TOKEN=your_sanity_api_read_token
# Sanity Write Token (Editor role token, optional for mutations, can be the same as read/manage if needed)
SANITY_API_WRITE_TOKEN=your_sanity_api_write_token

# Supabase Configuration (Obtain from your Supabase Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

